# Google Cloud credentials path
# Required at runtime for GCS upload and Google Speech-to-Text.
# Set this to the path of your own service account JSON file.
GOOGLE_APPLICATION_CREDENTIALS=
# Required when STT_V2_ENABLED=true so the implicit recognizer path can be built.
GOOGLE_CLOUD_PROJECT=

# Google Cloud Storage
# Required at runtime. The upload pipeline stores normalized WAV audio in GCS.
GCS_BUCKET=

# SQLite configuration
SQLITE_PATH=./data/calls.db

# Speech-to-Text configuration
PRIMARY_LANGUAGE_CODE=si-LK
ALT_LANGUAGE_CODES=en-US
DIARIZATION_SPEAKER_COUNT=2
ENABLE_DIARIZATION=true
# Strict Sinhala mode uses si-LK only, no alternate languages, and no diarization.
STT_STRICT_SINHALA_MODE=true
# Enable Google Speech-to-Text V2 primary recognition for strict Sinhala requests.
STT_V2_ENABLED=false
STT_V2_REGION=asia-southeast1
STT_V2_MODEL=chirp_2
STT_CHUNK_TARGET_SECONDS=22
STT_CHUNK_MAX_SECONDS=25
STT_CHUNK_MIN_SECONDS=20
STT_CHUNK_MIN_SILENCE_MS=700
STT_CHUNK_OVERLAP_SECONDS=1.0
STT_PREPROCESS_ENABLE=true
STT_PREPROCESS_HIGHPASS_HZ=120
STT_PREPROCESS_HEADROOM_DB=1.0

# Optional processing
ENABLE_LANGUAGE_DETECTION=false
ENABLE_SENTIMENT=false

# Intent model configuration
# Set ONE of the following:
# - INTENT_MODEL_PATH to a local directory that contains actual model weights
# - INTENT_MODEL_NAME to a valid Hugging Face model id
# If you later add trained weights under backend/models/intent_model, you can use:
# INTENT_MODEL_PATH=./models/intent_model
INTENT_MODEL_NAME=
INTENT_MODEL_PATH=
INTENT_LABELS=Billing,Complaint,Fiber,New_Connection,Other,PEO_TV

# Server configuration
HOST=0.0.0.0
PORT=8000

# Hybrid fallback / quality gate
STT_ENABLE_HYBRID_FALLBACK=true
STT_MIN_CONFIDENCE=0.55
STT_MAX_EMPTY_CHUNK_RATIO=0.30
STT_MIN_TRANSCRIPT_CHARS=30
